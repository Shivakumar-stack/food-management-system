{
  "name": "foodbridge-enterprise",
  "version": "1.0.0",
  "description": "FoodBridge - Single Origin Enterprise Architecture",
  "main": "server.js",
  "scripts": {
    "build:css": "npx tailwindcss -i ./css/main.css -o ./css/styles.css --minify",
    "watch:css": "npx tailwindcss -i ./css/main.css -o ./css/styles.css --watch",
    "lint": "echo 'Frontend lint: HTML/CSS validation' && exit 0",
    "serve": "npx live-server --port=5500 --open=/pages/index.html",
    "test:smoke": "playwright test --config=playwright.smoke.config.js",
    "test:smoke:headed": "playwright test --config=playwright.smoke.config.js --headed",
    "start": "npm run serve",
    "dev": "npm run serve",
    "prod": "cross-env NODE_ENV=production node server.js",
    "install:all": "npm install && cd frontend && npm install"
  },
  "keywords": [
    "food-donation",
    "ngo",
    "volunteer",
    "tailwind",
    "html",
    "foodbridge",
    "express",
    "single-origin"
  ],
  "author": "FoodBridge DevOps Team",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "mongoose": "^8.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "live-server": "^1.2.0",
    "tailwindcss": "^3.4.1",
    "nodemon": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}